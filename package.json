{
  "name": "@datalackey/qwiki",
  "version": "0.1.1",
  "description": "Bootstrap a MediaWiki from local Markdown files",
  "bin": {
    "qwiki": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "qwiki": "npx tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:e2e": "tsx tests/e2e/e2e.ts",
    "update-markdown-docs": "autogen-markdown-doc update README.md",
    "check-markdown-docs": "autogen-markdown-doc check README.md"
  },
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "gray-matter": "4.0.3",
    "pandoc-wasm": "1.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@datalackey/autogen-markdown-doc": "^1.4.11",
    "@datalackey/typescript-build-config": "^0.1.4",
    "@types/node": "^22.20.1",
    "tsx": "4.23.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
